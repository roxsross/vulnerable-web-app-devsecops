{
  "name": "vulnerable-web-app-devsecops",
  "version": "1.0.0",
  "description": "Aplicación web intencionalmente vulnerable para enseñanza de DevSecOps",
  "main": "index.js",
  "scripts": {
    "dev": "netlify dev",
    "build": "echo 'No build process needed for static files'",
    "deploy": "netlify deploy --prod",
    "test": "node test/runner.js",
    "test:coverage": "c8 --reporter=html --reporter=text --reporter=text-summary --reporter=lcov node test/runner.js",
    "test:watch": "nodemon --watch test --exec npm test",
    "coverage": "npm run test:coverage && open coverage/index.html",
    "coverage:report": "c8 report --reporter=text-summary",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "security:check": "npm audit && retire --path ."
  },
  "keywords": [
    "vulnerable",
    "devsecops",
    "security",
    "owasp",
    "education"
  ],
  "author": "ekoparty DevSecOps Course",
  "license": "MIT",
  "dependencies": {
    "@netlify/functions": "^2.8.1",
    "axios": "0.21.1",
    "express": "4.17.1",
    "jsonwebtoken": "^9.0.2",
    "lodash": "4.17.15"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "netlify-cli": "^17.36.4",
    "node-fetch": "^2.7.0",
    "retire": "^5.2.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/vulnerable-app-devsecops"
  },
  "notes": {
    "vulnerabilities": [
      "lodash@4.17.15 - CVE-2019-10744 (Prototype Pollution)",
      "lodash@4.17.15 - CVE-2020-8203 (Prototype Pollution)",
      "axios@0.21.1 - CVE-2021-3749 (Regular Expression Denial of Service)",
      "express@4.17.1 - CVE-2022-24999 (Open Redirect)"
    ],
    "detection": "Ejecutar 'npm audit' para ver todas las vulnerabilidades",
    "tools": [
      "SAST: npm audit, Snyk, WhiteSource",
      "SCA: OWASP Dependency-Check, retire.js"
    ]
  }
}
