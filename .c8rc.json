{
  "all": true,
  "include": [
    "netlify/functions/**/*.js",
    "public/**/*.js"
  ],
  "exclude": [
    "test/**",
    "coverage/**",
    "node_modules/**",
    "**/*.test.js",
    "**/*.spec.js"
  ],
  "reporter": [
    "html",
    "text",
    "text-summary",
    "lcov"
  ],
  "check-coverage": false,
  "lines": 80,
  "functions": 80,
  "branches": 80,
  "statements": 80,
  "temp-directory": ".nyc_output",
  "report-dir": "coverage"
}
